{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "TalentBridgeApplication",
            "request": "launch",
            "mainClass": "com.talentbridge.TalentBridgeApplication",
            "projectName": "talentbridge-api",
            "env": {
                "DB_HOST": "localhost",
                "DB_PORT": "5432",
                "DB_NAME": "TalentBridge",
                "DB_USERNAME": "postgres",
                "DB_PASSWORD": "<your_db_password>",
                "JWT_SECRET": "<output of: openssl rand -base64 64>",
                "JWT_EXPIRATION": "86400000",
                "JWT_REFRESH_EXPIRATION": "604800000",
                "ANTHROPIC_API_KEY": "<your_anthropic_api_key>",
                "ONET_API_KEY": "<your_onet_api_key>",
                "AWS_S3_RESUME_BUCKET": "<your_s3_bucket>",
                "AWS_SES_FROM_EMAIL": "noreply@yourdomain.com",
                "CORS_ORIGINS": "http://localhost:3000",
                "FRONTEND_URL": "http://localhost:3000"
            }
        }
    ]
}
