# TalentBridge — Backend Environment Variables
# Copy this file to .env.local and fill in your values.
# The backend reads these via IntelliJ run config, VS Code launch.json, or
# system environment variables (e.g. export $(cat .env.local | xargs)).
#
# Never commit .env.local to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=TalentBridge
DB_USERNAME=postgres
DB_PASSWORD=your_local_db_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=replace_with_a_strong_random_base64_string
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Obtain at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── O*NET Web Services ────────────────────────────────────────────────────────
# Register at: https://services.onetcenter.org/developer/
ONET_API_KEY=your_onet_api_key

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_S3_RESUME_BUCKET=your-s3-bucket-name
AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# ── Frontend origin (for CORS) ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
