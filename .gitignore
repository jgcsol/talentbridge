frontend/next-env.d.ts


# ── Backend (Spring Boot / Maven) ────────────────────────────────────────────
backend/target/*
backend/src/main/resources/application-local.yml

# IDE
.idea/
*.iml
*.iws
*.ipr

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Workspace storage ─────────────────────────────────────────────────────────
*.code-workspace

# Windows null device artifact
nul